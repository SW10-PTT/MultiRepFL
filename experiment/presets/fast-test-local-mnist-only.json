{
  "_doc": [
    "Fast local test preset — 10 tasks, 3 rounds, 1 epoch.",
    "12 users (5 selected per task) with task specialists, malicious, free-rider,",
    "and passive users designed to exercise every graph in multirep_plots.py.",
    "",
    "Expected behaviour:",
    "  TR[MNIST]  rises for MNIST experts, stays low for CIFAR experts (and vice-versa).",
    "  GIR rises for honest voters, falls for malicious/free-rider users.",
    "  Q builds up for unselected users (Passive A/B most visible).",
    "  Balance drops for punished users; rises for consistently honest contributors.",
    "  Confidence grows with task count; slow to mature for rarely-selected users.",
    "  Accuracy curves visible per task (run_data embedded in session pickle)."
  ],
  "name": "fast-test-local",
  "partition_file": "experiment/partitions/fast-test-6-users.json",
  "q_weight": 0.2,
  "tr_weight": 8,
  "gir_weight": 2,
  "training_mode": "remote",
  "fork": true,
  "replication_factor": 1.0,
  "allow_overlap": false,
  "seed": 42,
  "global_rep_only": false,
  "vote_baseline": "local_trained",
