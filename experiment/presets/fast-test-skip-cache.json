{
  "_doc": [
    "Regression test for SKIP_RUN_CACHE=True with remote mode.",
    "2 tasks, 1 round each — runs in ~1-2 minutes.",
    "Run twice back-to-back with SKIP_RUN_CACHE=True to verify",
    "has_run_data=True on both runs (second run hits same fingerprint dirs)."
  ],
  "name": "fast-test-skip-cache",
  "partition_file": "experiment/partitions/fast-test-6-users.json",
  "q_weight": 0.1,
  "tr_weight": 9,
  "gir_weight": 1,
  "training_mode": "remote",
  "priority": 100,
  "fork": true,
  "replication_factor": 1.0,
  "allow_overlap": true,
  "seed": 42,
  "global_rep_only": false,
  "vote_baseline": "local_trained",
