{
  "_doc": [
    "30-task showcase demonstrating task-specific reputation divergence.",
    "Users who are good at MNIST but bad at CIFAR-10 (M3, F3) should accumulate",
    "high MNIST TR and low CIFAR-10 TR over the session, causing the system to",
    "select them for MNIST tasks but deprioritise them for CIFAR-10 tasks.",
    "The reverse holds for M2/F2 (good CIFAR, bad MNIST).",
    "Tasks run in blocks of 5: 5x MNIST, then 5x CIFAR-10, repeated for 30 total."
  ],
  "name": "task-hopper-showcase",
  "partition_file": "experiment/partitions/EXP-mixed-distribution-all-honest-20-users.json",
  "q_weight": 0.1,
  "tr_weight": 9,
  "gir_weight": 1,
  "training_mode": "remote",
  "fork": true,
  "replication_factor": 4.0,
  "allow_overlap": true,
  "seed": 123,
  "global_rep_only": false,
  "vote_baseline": "local_trained",
