{
  "_doc": [
    "50-task showcase demonstrating task-specific reputation divergence.",
    "Users good at MNIST but bad at CIFAR-10 (M3, F3) accumulate high MNIST TR and low CIFAR-10 TR.",
    "Reverse holds for M2/F2. Tasks run in blocks of 10: 10x MNIST, then 10x CIFAR-10, repeated for 50 total."
  ],
  "name": "EXP-multirep-task-hopper-10-task-dataset-switch",
  "partition_file": "experiment/partitions/EXP-strong-task-hoppers-20-users.json",
  "q_weight": 0.2,
  "tr_weight": 8,
  "gir_weight": 2,
  "training_mode": "remote",
  "fork": true,
  "replication_factor": 4.0,
  "allow_overlap": true,
  "seed": 123,
  "global_rep_only": false,
  "vote_baseline": "local_trained",
  "tasks": [
